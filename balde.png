        var PHABLET_BREAKPOINT = 640;
        var ONE_SECOND_IN_MS = 1000;
        var ONE_MINUTE_IN_SECS = 60;
        var ONE_HOUR_IN_MINS = 60;
        var ONE_DAY_IN_HOURS = 24;
