            <span class="visually-hidden">más</span>
        </div>

    </div>
</div>

<div class="player-widget player-strip">

    <div class="player-strip__content">

        <div class="player-strip__info">
            <div class="player-strip__label">Lugar de nacimiento</div>
            <div class="player-strip__data">Barcelona, Spain</div>
        </div>

        <div class="player-strip__info">
